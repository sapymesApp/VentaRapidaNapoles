<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="MauiApp6.SeleccionarClientePopup"
               Color="Transparent">

    <Border BackgroundColor="White" 
            StrokeShape="RoundRectangle 15" 
            Padding="20" 
            WidthRequest="320"
            HeightRequest="450"
            VerticalOptions="Center"
            HorizontalOptions="Center">

        <Grid RowDefinitions="Auto, *, Auto" RowSpacing="15">
            <!-- Título -->
            <Label Grid.Row="0"
                   Text="Seleccionar Cliente" 
                   FontAttributes="Bold" 
                   FontSize="18"
                   HorizontalOptions="Center"
                   TextColor="Black"/>

            <!-- Búsqueda y Lista -->
            <Grid Grid.Row="1" RowDefinitions="Auto, *">
                <SearchBar x:Name="SbClientes"
                           Grid.Row="0"
                           Placeholder="Buscar por nombre..."
                           TextChanged="OnSearchBarTextChanged"
                           CancelButtonColor="Red" />

                <CollectionView Grid.Row="1" 
                                x:Name="CvClientes" 
                                SelectionMode="None"
                                Margin="0,10,0,0">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="10">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnClienteTapped"/>
                                </Grid.GestureRecognizers>

                                <Border BackgroundColor="#F5F5F5" StrokeShape="RoundRectangle 5" Padding="10">
                                    <VerticalStackLayout>
                                        <Label Text="{Binding Nombre}" FontAttributes="Bold" TextColor="Black"/>
                                        <Label Text="{Binding IdCliente, StringFormat='ID: {0}'}" FontSize="12" TextColor="Gray"/>
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    
                    <CollectionView.EmptyView>
                        <Label Text="No se encontraron clientes." 
                               HorizontalOptions="Center" 
                               VerticalOptions="Center" 
                               TextColor="Gray"
                               Margin="20"/>
                    </CollectionView.EmptyView>
                </CollectionView>
            </Grid>

            <!-- Botón Cancelar -->
            <Button Grid.Row="2"
                    Text="CANCELAR" 
                    Clicked="OnCancelarClicked" 
                    BackgroundColor="#F44336"
                    TextColor="White"
                    FontAttributes="Bold"/>
        </Grid>
    </Border>
</toolkit:Popup>
