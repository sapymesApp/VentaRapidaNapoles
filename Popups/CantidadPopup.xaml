<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="MauiApp6.CantidadPopup"
               Opened="OnPopupOpened"
               Color="Transparent">

    <Border BackgroundColor="White" 
            StrokeShape="RoundRectangle 15" 
            Padding="20" 
            WidthRequest="300"
            VerticalOptions="Center">

        <VerticalStackLayout Spacing="15">
            <Label x:Name="LblProducto" 
                   FontAttributes="Bold" 
                   FontSize="18"
                   HorizontalOptions="Center"
                   TextColor="Black"/>

            <Label x:Name="LblInstruccion" Text="Ingresa la cantidad:" FontSize="12" TextColor="Gray" HorizontalOptions="Center"/>

            <Entry x:Name="TxtCantidad" 
                   IsReadOnly="True"
                   Placeholder="0"
                   HorizontalTextAlignment="Center" 
                   FontSize="24"
                   TextColor="Black"
                   Completed="OnTxtCantidadCompleted"/>

            <Label x:Name="LblEquivalencia" 
                   Text="Equivale a: 0.000 Kg" 
                   FontSize="14" 
                   TextColor="#2196F3" 
                   FontAttributes="Italic, Bold"
                   HorizontalOptions="Center" 
                   IsVisible="False"
                   Margin="0,-5,0,10"/>
            

            <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="5" RowSpacing="5">
                <Button Text="7" Grid.Row="0" Grid.Column="0" Clicked="OnDigitClicked" BackgroundColor="#F1F1F1" TextColor="Black" FontSize="20" FontAttributes="Bold" Padding="10"/>
                <Button Text="8" Grid.Row="0" Grid.Column="1" Clicked="OnDigitClicked" BackgroundColor="#F1F1F1" TextColor="Black" FontSize="20" FontAttributes="Bold" Padding="10"/>
                <Button Text="9" Grid.Row="0" Grid.Column="2" Clicked="OnDigitClicked" BackgroundColor="#F1F1F1" TextColor="Black" FontSize="20" FontAttributes="Bold" Padding="10"/>

                <Button Text="4" Grid.Row="1" Grid.Column="0" Clicked="OnDigitClicked" BackgroundColor="#F1F1F1" TextColor="Black" FontSize="20" FontAttributes="Bold" Padding="10"/>
                <Button Text="5" Grid.Row="1" Grid.Column="1" Clicked="OnDigitClicked" BackgroundColor="#F1F1F1" TextColor="Black" FontSize="20" FontAttributes="Bold" Padding="10"/>
                <Button Text="6" Grid.Row="1" Grid.Column="2" Clicked="OnDigitClicked" BackgroundColor="#F1F1F1" TextColor="Black" FontSize="20" FontAttributes="Bold" Padding="10"/>

                <Button Text="1" Grid.Row="2" Grid.Column="0" Clicked="OnDigitClicked" BackgroundColor="#F1F1F1" TextColor="Black" FontSize="20" FontAttributes="Bold" Padding="10"/>
                <Button Text="2" Grid.Row="2" Grid.Column="1" Clicked="OnDigitClicked" BackgroundColor="#F1F1F1" TextColor="Black" FontSize="20" FontAttributes="Bold" Padding="10"/>
                <Button Text="3" Grid.Row="2" Grid.Column="2" Clicked="OnDigitClicked" BackgroundColor="#F1F1F1" TextColor="Black" FontSize="20" FontAttributes="Bold" Padding="10"/>

                <Button Text="." Grid.Row="3" Grid.Column="0" Clicked="OnDigitClicked" BackgroundColor="#F1F1F1" TextColor="Black" FontSize="20" FontAttributes="Bold" Padding="10"/>
                <Button Text="0" Grid.Row="3" Grid.Column="1" Clicked="OnDigitClicked" BackgroundColor="#F1F1F1" TextColor="Black" FontSize="20" FontAttributes="Bold" Padding="10"/>
                <Button Text="DEL" Grid.Row="3" Grid.Column="2" Clicked="OnBackspaceClicked" BackgroundColor="#FFCDD2" TextColor="DarkRed" FontSize="20" FontAttributes="Bold" Padding="10"/>
            </Grid>

            <HorizontalStackLayout x:Name="BotonesPrecios" Spacing="10" HorizontalOptions="Center" IsVisible="False">
                <Button x:Name="BtnPrecio1" Text="0.00" Clicked="OnPrecioClicked" BackgroundColor="#2196F3" TextColor="White" FontAttributes="Bold" IsVisible="False"/>
                <Button x:Name="BtnPrecio2" Text="0.00" Clicked="OnPrecioClicked" BackgroundColor="#2196F3" TextColor="White" FontAttributes="Bold" IsVisible="False"/>
                <Button x:Name="BtnPrecio3" Text="0.00" Clicked="OnPrecioClicked" BackgroundColor="#2196F3" TextColor="White" FontAttributes="Bold" IsVisible="False"/>
                <Button x:Name="BtnPrecio4" Text="0.00" Clicked="OnPrecioClicked" BackgroundColor="#2196F3" TextColor="White" FontAttributes="Bold" IsVisible="False"/>
            </HorizontalStackLayout>

            <Button x:Name="BtnAceptar" Text="ACEPTAR" 
                    Clicked="OnAceptarClicked" 
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    FontAttributes="Bold"
                    IsVisible="True"/>

            <Button x:Name="BtnModoMonto" 
            Text="Vender por $" 
            Clicked="OnModoMontoClicked" 
            BackgroundColor="#FF9800" 
            TextColor="White"
            FontAttributes="Bold"
            Margin="0,10,0,0"
            IsVisible="False"/>


        </VerticalStackLayout>
    </Border>
</toolkit:Popup>
    