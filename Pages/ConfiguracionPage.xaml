<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp6.ConfiguracionPage"          
             NavigationPage.HasNavigationBar="False"
             xmlns:controls="clr-namespace:MauiApp6.Controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             Title="Configuración">
    <ScrollView>
    <VerticalStackLayout Padding="20" Spacing="15">


            <Border BackgroundColor="White" StrokeThickness="0" Margin="15,10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15" />
                </Border.StrokeShape>

                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.08" />
                </Border.Shadow>

                <Grid RowDefinitions="Auto, *">

                    <Border Grid.Row="0" BackgroundColor="#F59E0B" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15,15,0,0" />
                        </Border.StrokeShape>

                        <HorizontalStackLayout Padding="20,12" Spacing="10" VerticalOptions="Center">
                            <Label Text="&#xe1a7;" FontFamily="MaterialIcons" FontSize="22" TextColor="White" VerticalOptions="Center"/>
                            <Label Text="Conexión de Impresora" FontSize="16" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                    <VerticalStackLayout Grid.Row="1" Padding="20,25,20,25" Spacing="20" BackgroundColor="White">

                        <Label Text="Seleccione el dispositivo Bluetooth al que se enviarán los tickets de venta." 
                   FontSize="14" TextColor="#6B7280" />

                        <Border Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="15,0,5,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>

                            <Picker x:Name="DevicePicker" 
                        Title="Selecciona una impresora..." 
                        TextColor="#111827"
                        TitleColor="#9CA3AF"
                        SelectedIndexChanged="OnDevicePickerSelectedIndexChanged"/>
                        </Border>

                        <controls:MenuButton 
                        ButtonText="Imprimir prueba" 
                        CardBackgroundColor="#FFFBEB" 
                        PrimaryColor="#F59E0B" 
                        IconGlyph="&#xe8b8;" 
                        Tapped="OnPrintClicked" />

                    </VerticalStackLayout>
                </Grid>
            </Border>





            <Border BackgroundColor="White" StrokeThickness="0" Margin="15,10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15" />
                </Border.StrokeShape>

                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.08" />
                </Border.Shadow>

                <Grid RowDefinitions="Auto, *">

                    <Border Grid.Row="0" BackgroundColor="#F59E0B" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15,15,0,0" />
                        </Border.StrokeShape>

                        <HorizontalStackLayout Padding="20,12" Spacing="10" VerticalOptions="Center">
                            <Label Text="&#xe32a;" FontFamily="MaterialIcons" FontSize="22" TextColor="White" VerticalOptions="Center"/>
                            <Label Text="Activación de Dispositivo" FontSize="16" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                    <VerticalStackLayout Grid.Row="1" Padding="20,25,20,25" Spacing="20" BackgroundColor="White">

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Clave de la empresa" FontSize="14" FontAttributes="Bold" TextColor="#4B5563" />

                            <Border Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="15,0,5,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Entry x:Name="txtEmpresa" 
                           FontSize="16" 
                           Text="{Binding Empresa}" 
                           IsEnabled="{Binding NotDispositivoAutorizado}"
                           TextColor="#111827">
                                    <Entry.Behaviors>
                                        <toolkit:EventToCommandBehavior 
                                EventName="Unfocused" 
                                Command="{Binding GuardarEmpresa}" />
                                    </Entry.Behaviors>
                                </Entry>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Identificador de dispositivo" FontSize="14" FontAttributes="Bold" TextColor="#4B5563" />

                            <Border Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F3F4F6" Padding="15,0,5,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Entry x:Name="txtID" 
                           IsEnabled="False" 
                           FontSize="16" 
                           Text="{Binding AndroidID}"
                           TextColor="#6B7280" />
                            </Border>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="#E5E7EB" Margin="0,10" />

                        <VerticalStackLayout Spacing="12">
                            <controls:MenuButton x:Name="btnActivar"         
                    ButtonText="Enviar datos de activación" 
                    CardBackgroundColor="#FFFBEB" 
                    PrimaryColor="#F59E0B" 
                    IconGlyph="&#xf502;" 
                    IsVisible="{Binding NotDispositivoAutorizado}"
                    Command="{Binding ActivarCommand}" />

                            <controls:MenuButton x:Name="btnValidar"         
                    ButtonText="Comprobar activación" 
                    CardBackgroundColor="#FFFBEB" 
                    PrimaryColor="#F59E0B" 
                    IconGlyph="&#xe73c;" 
                    IsVisible="{Binding NotDispositivoAutorizado}"
                    Command="{Binding ValidarDispositivoCommand}" />

                            <controls:MenuButton x:Name="btnEmpresa"         
                    ButtonText="Descargar imágenes de la empresa" 
                    CardBackgroundColor="#FFFBEB" 
                    PrimaryColor="#F59E0B" 
                    IconGlyph="&#xe43f;" 
                    Command="{Binding DescargarEmpresaCommand}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="10" Margin="0,10,0,0">
                            <ActivityIndicator IsRunning="{Binding IsBusy}" 
                                   Color="#0284C7"
                                   HeightRequest="40" 
                                   WidthRequest="40"
                                   HorizontalOptions="Center"/>

                            <Label x:Name="LblStatus"
                       Text=""
                       TextColor="#10B981"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Grid>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
