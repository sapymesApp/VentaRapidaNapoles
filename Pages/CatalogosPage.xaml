<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp6.CatalogosPage"
             NavigationPage.HasNavigationBar="False"
             xmlns:controls="clr-namespace:MauiApp6.Controls"             
             BackgroundColor="#F0F0F0">
    <Grid RowDefinitions="Auto, *" BackgroundColor="#F3F4F6">

        <Border Grid.Row="0" BackgroundColor="#0284C7" StrokeThickness="0" Padding="20,30,20,60" Margin="0,0,0,-40" ZIndex="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,30,30" />
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                <Label Text="&#xe40a;" FontFamily="MaterialIcons" FontSize="36" TextColor="White" HorizontalOptions="Center"/>
                <Label Text="Catálogos" FontSize="26" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />
                <Label Text="Seleccione el catálogo a consultar" FontSize="14" TextColor="#E0F2FE" HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Border>

        <ScrollView Grid.Row="1" ZIndex="1">
            <VerticalStackLayout Padding="20,0,20,30">

                <Border BackgroundColor="White" StrokeThickness="0" Padding="20,25" Margin="0,15,0,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.05" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="15">

                        <controls:MenuButton 
                        ButtonText="Inventarios" 
                        CardBackgroundColor="#E0F2FE" 
                        PrimaryColor="#0284C7" 
                        IconGlyph="&#xe02f;" 
                        Tapped="OnInventariosTapped" />

                        <controls:MenuButton 
                        ButtonText="Clientes" 
                        CardBackgroundColor="#E0F2FE" 
                        PrimaryColor="#0284C7" 
                        IconGlyph="&#xe7fb;" 
                        Tapped="OnClientesTapped" />

                        <controls:MenuButton 
                        ButtonText="Abonos" 
                        CardBackgroundColor="#E0F2FE" 
                        PrimaryColor="#0284C7" 
                        IconGlyph="&#xe227;" 
                        Tapped="OnAbonosTapped" />

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
