<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp6.SincronizacionPage"
             NavigationPage.HasNavigationBar="False"
             xmlns:controls="clr-namespace:MauiApp6.Controls">
    <Border BackgroundColor="White" StrokeThickness="0" Margin="15,10">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="15" />
        </Border.StrokeShape>

        <Border.Shadow>
            <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.08" />
        </Border.Shadow>

        <Grid RowDefinitions="Auto, *">

            <Border Grid.Row="0" BackgroundColor="#475569" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15,15,0,0" />
                </Border.StrokeShape>

                <HorizontalStackLayout Padding="20,15" Spacing="12" VerticalOptions="Center">
                    <Label Text="&#xe1a1;" FontFamily="MaterialIcons" FontSize="26" TextColor="White" VerticalOptions="Center"/>
                    <VerticalStackLayout Spacing="0" VerticalOptions="Center">
                        <Label Text="Sincronización" FontSize="18" FontAttributes="Bold" TextColor="White" />
                        <Label Text="Transmisión de datos al servidor" FontSize="12" TextColor="#E0F2FE" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Border>

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="20,25,20,25" Spacing="20" BackgroundColor="White">

                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center" Margin="0,0,0,10">
                        <Border BackgroundColor="#F0F9FF" WidthRequest="80" HeightRequest="80" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="40" />
                            </Border.StrokeShape>
                            <Label Text="&#xe627;" 
                               FontFamily="MaterialIcons" 
                               FontSize="40" 
                               TextColor="#0284C7" 
                               HorizontalOptions="Center" 
                               VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Mantén tu catálogo al día" FontSize="14" TextColor="#6B7280" HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <Label Text="Recepción de datos" FontSize="14" FontAttributes="Bold" TextColor="#4B5563" Margin="0,10,0,0" />

                    <controls:MenuButton 
                    ButtonText="Validar" 
                    IsEnabled="{Binding NotDispositivoAutorizado}"
                    CardBackgroundColor="#F8FAFC" 
                    PrimaryColor="#475569" 
                    IconGlyph="&#xe6b3;"
                    Command="{Binding ValidarCommand}" />

                    <controls:MenuButton x:Name="btnCatalogo" 
                    IsEnabled="{Binding btnCatalogo}"
                    ButtonText="Descargar Catálogos" 
                    CardBackgroundColor="#F8FAFC" 
                    PrimaryColor="#475569" 
                    IconGlyph="&#xe2c4;" 
                    Command="{Binding DescargarCommand}" />

                    <BoxView HeightRequest="1" Color="#E5E7EB" Margin="0,10" />

                    <Label Text="Envío al servidor" FontSize="14" FontAttributes="Bold" TextColor="#4B5563" />

                    <controls:MenuButton  x:Name="btnVentas"
                    IsEnabled="{Binding DispositivoAutorizado}"
                    ButtonText="Subir ventas pendientes" 
                    CardBackgroundColor="#F8FAFC" 
                    PrimaryColor="#475569" 
                    IconGlyph="&#xe2c6;" 
                    Command="{Binding SubirVentasCommand}" />

                    <controls:MenuButton x:Name="btnAbonos"
                    IsEnabled="{Binding DispositivoAutorizado}"
                    ButtonText="Subir abonos" 
                    CardBackgroundColor="#F8FAFC" 
                    PrimaryColor="#475569" 
                    IconGlyph="&#xe2c6;" 
                    Command="{Binding SubirAbonosCommand}" />


                    <VerticalStackLayout Spacing="10" Margin="0,15,0,0">
                        <ActivityIndicator IsRunning="{Binding IsBusy}" 
                                       Color="#0284C7"
                                       HeightRequest="40" 
                                       WidthRequest="40"
                                       HorizontalOptions="Center"/>

                        <Label Text="{Binding MensajeEstado}"
                           TextColor="#4B5563"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Border>
</ContentPage>