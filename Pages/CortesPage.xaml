<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp6.CortesPage"
             xmlns:controls="clr-namespace:MauiApp6.Controls"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F4F6F8">

    <Border BackgroundColor="White" StrokeThickness="0" Margin="15,10">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="15" />
        </Border.StrokeShape>

        <Border.Shadow>
            <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.08" />
        </Border.Shadow>

        <Grid RowDefinitions="Auto, *">

            <Border Grid.Row="0" BackgroundColor="#3F51B5" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15,15,0,0" />
                </Border.StrokeShape>

                <HorizontalStackLayout Padding="20,15" Spacing="12" VerticalOptions="Center">
                    <Label Text="&#xe859;" FontFamily="MaterialIcons" FontSize="28" TextColor="White" VerticalOptions="Center"/>
                    <VerticalStackLayout Spacing="0" VerticalOptions="Center">
                        <Label Text="Corte de Caja" FontSize="18" FontAttributes="Bold" TextColor="White" />
                        <Label Text="Consulta los ingresos del periodo" FontSize="12" TextColor="#E0F2FE" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Border>

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="20,25,20,25" Spacing="25" BackgroundColor="White">

                    <VerticalStackLayout Spacing="12">
                        <Label Text="Periodo de Consulta" FontSize="14" FontAttributes="Bold" TextColor="#4B5563" />

                        <Grid ColumnDefinitions="*, *" ColumnSpacing="15">

                            <VerticalStackLayout Grid.Column="0" Spacing="6">
                                <Label Text="Desde:" FontSize="12" FontAttributes="Bold" TextColor="#6B7280" />
                                <Border Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="10,0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8" />
                                    </Border.StrokeShape>
                                    <DatePicker x:Name="DpInicio" Format="dd MMM yyyy" TextColor="#111827" BackgroundColor="Transparent" />
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="6">
                                <Label Text="Hasta:" FontSize="12" FontAttributes="Bold" TextColor="#6B7280" />
                                <Border Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="10,0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8" />
                                    </Border.StrokeShape>
                                    <DatePicker x:Name="DpFin" Format="dd MMM yyyy" TextColor="#111827" BackgroundColor="Transparent" />
                                </Border>
                            </VerticalStackLayout>

                        </Grid>

                        <controls:MenuButton 
                          ButtonText="Mostrar corte" 
                          CardBackgroundColor="#E8EAF6" 
                          PrimaryColor="#3F51B5" 
                          IconGlyph="&#xe24a;" 
                          Tapped="OnCalcularCorteClicked" />
                    </VerticalStackLayout>


                    <VerticalStackLayout x:Name="SlResultados" IsVisible="False" Spacing="15">

                        <BoxView HeightRequest="1" Color="#E5E7EB" Margin="0,5" />

                        <Label Text="Resumen de Operaciones" FontSize="14" FontAttributes="Bold" TextColor="#4B5563" />

                        <Border BackgroundColor="#F0F9FF" Stroke="#E0F2FE" StrokeThickness="1" Padding="15">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto, *">
                                <Border Grid.Column="0" BackgroundColor="#BAE6FD" WidthRequest="46" HeightRequest="46" StrokeThickness="0" VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="23" />
                                    </Border.StrokeShape>
                                    <Label Text="&#xe8cc;" FontFamily="MaterialIcons" FontSize="22" TextColor="#0284C7" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Margin="15,0,0,0" VerticalOptions="Center">
                                    <Label Text="Total Ventas" FontSize="12" FontAttributes="Bold" TextColor="#6B7280" />
                                    <Label x:Name="LblTotalVentas" Text="$0.00" FontSize="20" FontAttributes="Bold" TextColor="#111827" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                        <Border BackgroundColor="#ECFDF5" Stroke="#D1FAE5" StrokeThickness="1" Padding="15">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto, *">
                                <Border Grid.Column="0" BackgroundColor="#A7F3D0" WidthRequest="46" HeightRequest="46" StrokeThickness="0" VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="23" />
                                    </Border.StrokeShape>
                                    <Label Text="&#xe227;" FontFamily="MaterialIcons" FontSize="22" TextColor="#059669" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Margin="15,0,0,0" VerticalOptions="Center">
                                    <Label Text="Total abonos/pagos" FontSize="12" FontAttributes="Bold" TextColor="#6B7280" />
                                    <Label x:Name="LblTotalAbonos" Text="$0.00" FontSize="20" FontAttributes="Bold" TextColor="#111827" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                        <!--<Border BackgroundColor="#10B981" StrokeThickness="0" Padding="20" Margin="0,10,0,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="15" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#10B981" Offset="0,4" Opacity="0.3" Radius="8"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                                <Label Text="INGRESOS TOTALES" FontSize="13" TextColor="#D1FAE5" FontAttributes="Bold" HorizontalOptions="Center" />
                                <Label x:Name="LblGranTotal" Text="$0.00" FontSize="36" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>-->

                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Border>

</ContentPage>
