<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp6.EditarPrecioPage"
             xmlns:controls="clr-namespace:MauiApp6.Controls" 
             NavigationPage.HasNavigationBar="False">
    <Grid RowDefinitions="Auto, *" BackgroundColor="#F3F4F6">

        <Border Grid.Row="0" BackgroundColor="#0284C7" StrokeThickness="0" Padding="20,30,20,60" Margin="0,0,0,-40" ZIndex="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,30,30" />
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                <Label Text="&#xe3c9;" FontFamily="MaterialIcons" FontSize="36" TextColor="White" HorizontalOptions="Center"/>
                <Label Text="Editar Producto" FontSize="24" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />
                <Label Text="Actualiza la información del catálogo" FontSize="14" TextColor="#E0F2FE" HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Border>

        <ScrollView Grid.Row="1" ZIndex="1">
            <VerticalStackLayout Padding="20,0,20,30">

                <Border BackgroundColor="White" StrokeThickness="0" Padding="20,25" Margin="0,15,0,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.05" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="20">

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Descripción del producto" FontSize="14" FontAttributes="Bold" TextColor="#4B5563" />

                            <Border Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="15,0,5,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Entry x:Name="TxtDescripcion" 
                                   FontSize="16" 
                                   TextColor="#111827"
                                   Placeholder="Ej. Refresco de Cola 600ml"
                                   PlaceholderColor="#9CA3AF"
                                   ReturnType="Next"
                                   MaxLength="60"
                                   ClearButtonVisibility="WhileEditing"
                                   BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Costo" FontSize="14" FontAttributes="Bold" TextColor="#4B5563" />

                            <Border Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="15,0,5,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>

                                <Grid ColumnDefinitions="Auto, *">
                                    <Label Grid.Column="0" Text="$" FontSize="18" FontAttributes="Bold" TextColor="#9CA3AF" VerticalOptions="Center" Margin="0,0,5,0"/>

                                    <Entry x:Name="TxtCosto" 
                                       Grid.Column="1"
                                       Keyboard="Numeric" 
                                       FontSize="18"
                                       TextColor="#111827"
                                       Placeholder="0.00"
                                       PlaceholderColor="#9CA3AF"
                                       ReturnType="Next"
                                       BackgroundColor="Transparent"/>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Precio de venta 1" FontSize="14" FontAttributes="Bold" TextColor="#4B5563" />

                            <Border Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="15,0,5,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>

                                <Grid ColumnDefinitions="Auto, *">
                                    <Label Grid.Column="0" Text="$" FontSize="18" FontAttributes="Bold" TextColor="#9CA3AF" VerticalOptions="Center" Margin="0,0,5,0"/>

                                    <Entry x:Name="TxtPrecio" 
                                       Grid.Column="1"
                                       Keyboard="Numeric" 
                                       FontSize="18"
                                       TextColor="#111827"
                                       Placeholder="0.00"
                                       PlaceholderColor="#9CA3AF"
                                       ReturnType="Next"
                                       BackgroundColor="Transparent"/>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Precio de venta 2" FontSize="14" FontAttributes="Bold" TextColor="#4B5563" />

                            <Border Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="15,0,5,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>

                                <Grid ColumnDefinitions="Auto, *">
                                    <Label Grid.Column="0" Text="$" FontSize="18" FontAttributes="Bold" TextColor="#9CA3AF" VerticalOptions="Center" Margin="0,0,5,0"/>

                                    <Entry x:Name="TxtPrecio2" 
                                       Grid.Column="1"
                                       Keyboard="Numeric" 
                                       FontSize="18"
                                       TextColor="#111827"
                                       Placeholder="0.00"
                                       PlaceholderColor="#9CA3AF"
                                       ReturnType="Next"
                                       BackgroundColor="Transparent"/>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Precio de venta 3" FontSize="14" FontAttributes="Bold" TextColor="#4B5563" />

                            <Border Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="15,0,5,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>

                                <Grid ColumnDefinitions="Auto, *">
                                    <Label Grid.Column="0" Text="$" FontSize="18" FontAttributes="Bold" TextColor="#9CA3AF" VerticalOptions="Center" Margin="0,0,5,0"/>

                                    <Entry x:Name="TxtPrecio3" 
                                       Grid.Column="1"
                                       Keyboard="Numeric" 
                                       FontSize="18"
                                       TextColor="#111827"
                                       Placeholder="0.00"
                                       PlaceholderColor="#9CA3AF"
                                       ReturnType="Next"
                                       BackgroundColor="Transparent"/>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Precio de venta 4" FontSize="14" FontAttributes="Bold" TextColor="#4B5563" />

                            <Border Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="15,0,5,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>

                                <Grid ColumnDefinitions="Auto, *">
                                    <Label Grid.Column="0" Text="$" FontSize="18" FontAttributes="Bold" TextColor="#9CA3AF" VerticalOptions="Center" Margin="0,0,5,0"/>

                                    <Entry x:Name="TxtPrecio4" 
                                       Grid.Column="1"
                                       Keyboard="Numeric" 
                                       FontSize="18"
                                       TextColor="#111827"
                                       Placeholder="0.00"
                                       PlaceholderColor="#9CA3AF"
                                       ReturnType="Done"
                                       Completed="MenuButton_Tapped"
                                       BackgroundColor="Transparent"/>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="#E5E7EB" Margin="0,10" />

                        <VerticalStackLayout Spacing="12">

                            <controls:MenuButton 
                            ButtonText="Guardar cambios" 
                            CardBackgroundColor="#E0F2FE" 
                            PrimaryColor="#0284C7" 
                            IconGlyph="&#xe877;" 
                            Tapped="MenuButton_Tapped" />

                            <!--<Button Text="Guardar Cambios" 
                                Clicked="OnActualizarClicked" 
                                BackgroundColor="#0284C7"
                                TextColor="White"
                                CornerRadius="10"
                                FontAttributes="Bold"
                                FontSize="16"
                                HeightRequest="50">
                                <Button.Shadow>
                                    <Shadow Brush="#0284C7" Offset="0,4" Radius="8" Opacity="0.3" />
                                </Button.Shadow>
                            </Button>-->

                            <!--<Button Text="Cancelar" 
                                Clicked="OnCancelarClicked" 
                                BackgroundColor="Transparent"
                                TextColor="#6B7280"
                                FontAttributes="Bold"
                                FontSize="15"
                                HeightRequest="45" />-->

                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>