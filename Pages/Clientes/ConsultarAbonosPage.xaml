<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             NavigationPage.HasNavigationBar="False"
             x:Class="MauiApp6.ConsultarAbonosPage"
             Title="Consultar Abonos">

    <Grid RowDefinitions="Auto, *" BackgroundColor="#F3F4F6">

        <Border Grid.Row="0" BackgroundColor="White" StrokeThickness="0" ZIndex="1">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.05"/>
            </Border.Shadow>

            <VerticalStackLayout Padding="20,15" Spacing="12">

                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                    <Label Text="&#xe227;" FontFamily="MaterialIcons" FontSize="24" TextColor="#10B981" VerticalOptions="Center"/>
                    <Label Text="Historial de abonos/pagos" FontSize="20" FontAttributes="Bold" TextColor="#111827" VerticalOptions="Center" />
                </HorizontalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="Fecha de consulta" FontSize="12" FontAttributes="Bold" TextColor="#6B7280" />
                    <Border Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="10,0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <DatePicker x:Name="DpFecha" 
                                DateSelected="OnDateSelected" 
                                Format="dd MMM yyyy"
                                TextColor="#111827"
                                BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </Border>

        <CollectionView Grid.Row="1" x:Name="CvAbonos" Margin="0,10,0,0">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Border BackgroundColor="White" 
                        Stroke="#E5E7EB" 
                        StrokeThickness="1" 
                        Margin="15,6" 
                        Padding="15" 
                        StrokeShape="RoundRectangle 15">

                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.03"/>
                        </Border.Shadow>

                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">

                            <Border Grid.Column="0" WidthRequest="44" HeightRequest="44" BackgroundColor="#ECFDF5" StrokeThickness="0" VerticalOptions="Start">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="22" />
                                </Border.StrokeShape>
                                <Label Text="&#xe2c4;" FontFamily="MaterialIcons" TextColor="#10B981" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="{Binding ClienteNombre}" FontSize="15" FontAttributes="Bold" TextColor="#111827" LineBreakMode="TailTruncation" />
                                <Label Text="{Binding VentasId, StringFormat='Folio Venta: {0}'}" FontSize="12" TextColor="#6B7280" />

                                <HorizontalStackLayout Spacing="4" Margin="0,4,0,0">
                                    <Label Text="&#xe8b5;" FontFamily="MaterialIcons" FontSize="14" TextColor="#9CA3AF" VerticalOptions="Center"/>
                                    <Label Text="{Binding Fecha, StringFormat='{0:HH:mm}'}" FontSize="12" TextColor="#9CA3AF" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="End">
                                <Label Text="Abono" FontSize="10" TextColor="#9CA3AF" HorizontalOptions="End" />
                                <Label Text="{Binding AbonoMonto, StringFormat='+{0:C}'}" FontSize="18" FontAttributes="Bold" TextColor="#10B981" HorizontalOptions="End" />
                            </VerticalStackLayout>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" Margin="0,80">
                    <Label Text="&#xe8b6;" FontFamily="MaterialIcons" FontSize="80" TextColor="#D1D5DB" HorizontalOptions="Center"/>
                    <Label Text="No hay abonos en esta fecha" FontSize="16" FontAttributes="Bold" TextColor="#4B5563" HorizontalOptions="Center"/>
                    <Label Text="Intenta seleccionando otro día." FontSize="14" TextColor="#9CA3AF" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

        </CollectionView>

    </Grid>
</ContentPage>
