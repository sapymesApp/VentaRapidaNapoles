<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             NavigationPage.HasNavigationBar="False"
             x:Class="MauiApp6.VentasClientePage">
    <ContentPage.Content>
        <Grid RowDefinitions="Auto, *, Auto" BackgroundColor="#F3F4F6">

            <Border Grid.Row="0" BackgroundColor="White" StrokeThickness="0" ZIndex="1">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.05"/>
                </Border.Shadow>

                <VerticalStackLayout Padding="15,20">

                    <Grid ColumnDefinitions="Auto, *" VerticalOptions="Center" Margin="0,0,0,15">
                        <ImageButton BackgroundColor="#F9FAFB" 
                                 Clicked="OnVolverClicked"
                                 WidthRequest="40" HeightRequest="40"
                                 CornerRadius="20">
                            <ImageButton.Source>
                                <FontImageSource FontFamily="MaterialIcons" Glyph="&#xe5c4;" Color="#4B5563" Size="22"/>
                            </ImageButton.Source>
                        </ImageButton>

                        <Label Grid.Column="1" 
                           x:Name="LblNombreCliente" 
                           Text="Ventas de Cliente" 
                           FontSize="20" 
                           FontAttributes="Bold" 
                           TextColor="#A855F7"
                           VerticalOptions="Center"
                           Margin="15,0,0,0"
                           LineBreakMode="TailTruncation"/>
                    </Grid>

                    <Grid ColumnDefinitions="*, *, Auto" ColumnSpacing="10" VerticalOptions="End">

                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Desde:" FontSize="11" FontAttributes="Bold" TextColor="#6B7280"/>
                            <Border Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="5,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <DatePicker x:Name="DpDesde" DateSelected="OnFiltrosChanged" Format="dd MMM yy" TextColor="#111827" BackgroundColor="Transparent" FontSize="13"/>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Hasta:" FontSize="11" FontAttributes="Bold" TextColor="#6B7280"/>
                            <Border Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F9FAFB" Padding="5,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <DatePicker x:Name="DpHasta" DateSelected="OnFiltrosChanged" Format="dd MMM yy" TextColor="#111827" BackgroundColor="Transparent" FontSize="13"/>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="2" Spacing="4" VerticalOptions="Center">
                            <Label Text="Pagadas" FontSize="11" FontAttributes="Bold" TextColor="#6B7280" HorizontalOptions="Center"/>
                            <Switch x:Name="SwIncluirPagadas" IsToggled="False" Toggled="OnFiltrosChanged" OnColor="#10B981" HorizontalOptions="Center" Scale="0.8"/>
                        </VerticalStackLayout>

                    </Grid>
                </VerticalStackLayout>
            </Border>

            <CollectionView Grid.Row="1" x:Name="CvVentas" SelectionMode="Single" SelectionChanged="OnVentasSelected" Margin="0,10,0,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <Border BackgroundColor="White" Stroke="#E5E7EB" StrokeThickness="1" Margin="15,6" Padding="15" StrokeShape="RoundRectangle 12">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.03"/>
                            </Border.Shadow>

                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">

                                <Border Grid.Column="0" WidthRequest="44" HeightRequest="44" BackgroundColor="#F3E8FF" StrokeThickness="0" VerticalOptions="Start">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="22" />
                                    </Border.StrokeShape>
                                    <Label Text="&#xe8cc;" FontFamily="MaterialIcons" FontSize="22" TextColor="#A855F7" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="{Binding Fecha, StringFormat='{0:dd MMM yyyy}'}" FontAttributes="Bold" FontSize="15" TextColor="#111827"/>
                                    <Label Text="{Binding Id, StringFormat='Folio: {0}'}" FontSize="12" TextColor="#6B7280"/>

                                    <Border Padding="8,2" StrokeThickness="0" HorizontalOptions="Start" Margin="0,4,0,0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="8" />
                                        </Border.StrokeShape>
                                        <Label Text="{Binding Status}" FontSize="10" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Saldada">
                                                <Setter Property="BackgroundColor" Value="#10B981" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Abierta">
                                                <Setter Property="BackgroundColor" Value="#F59E0B" />
                                            </DataTrigger>
                                        </Border.Triggers>
                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="4">
                                    <Label Text="{Binding Total, StringFormat='{0:C}'}" FontSize="16" FontAttributes="Bold" TextColor="#111827" HorizontalOptions="End"/>

                                    <Label Text="{Binding Saldo, StringFormat='Saldo {0:C}'}" FontSize="12" FontAttributes="Bold" TextColor="#EF4444" HorizontalOptions="End"/>
                                </VerticalStackLayout>

                            </Grid>
                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" Margin="0,80">
                        <Label Text="&#xe8b6;" FontFamily="MaterialIcons" FontSize="80" TextColor="#D1D5DB" HorizontalOptions="Center"/>
                        <Label Text="No se encontraron ventas" FontSize="16" FontAttributes="Bold" TextColor="#4B5563" HorizontalOptions="Center"/>
                        <Label Text="Prueba cambiando los filtros de fecha." FontSize="14" TextColor="#9CA3AF" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>

            <Border Grid.Row="2" BackgroundColor="White" StrokeThickness="0" Padding="20,15,20,25" ZIndex="1">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,-4" Opacity="0.05" Radius="10" />
                </Border.Shadow>

                <Button x:Name="BtnExportarPdf"
                    Text="Exportar estado de cuenta (PDF)"
                    BackgroundColor="#0284C7"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    HeightRequest="50"
                    Clicked="OnExportarPDFClicked">
                    <Button.Shadow>
                        <Shadow Brush="#0284C7" Offset="0,4" Radius="8" Opacity="0.3" />
                    </Button.Shadow>
                    <Button.ImageSource>
                        <FontImageSource FontFamily="MaterialIcons" Glyph="&#xe80df;" Color="White" />
                    </Button.ImageSource>
                </Button>
            </Border>

        </Grid>
    </ContentPage.Content>
</ContentPage>
